# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────

# Your MetaMask wallet private key (NEVER share this or commit to git)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_metamask_private_key_here

# Polygon Amoy Testnet RPC URL (free from Alchemy or Infura)
# Sign up at: https://www.alchemy.com → Create App → Polygon Amoy
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key_here

# Polygonscan API Key (for contract verification — free)
# Get at: https://amoy.polygonscan.com → Sign In → API Keys
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Claude AI API Key (for AI chat assistant)
# Get at: https://console.anthropic.com → API Keys
REACT_APP_CLAUDE_API_KEY=sk-ant-api03-your_key_here
